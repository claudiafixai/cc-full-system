# CC Full System — Environment Variables
# Copy this file to ~/.claude/.env and fill in your values
# Never commit .env to git

# ─── REQUIRED ──────────────────────────────────────────────────────────────

# Your Anthropic API key — get it at console.anthropic.com
ANTHROPIC_API_KEY=

# ─── MONITORING (add as you connect services) ──────────────────────────────

# Vercel — vercel.com → Settings → Tokens
VERCEL_TOKEN=

# Sentry — sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Supabase — supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# ─── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────────

# UptimeRobot — for SSL cert monitor uptime history
# Get at: uptimerobot.com → My Settings → API Settings → Main API Key
UPTIMEROBOT_API_KEY=

# Plausible Analytics — for traffic data in metrics-synthesizer
# Get at: plausible.io → Settings → API Keys
PLAUSIBLE_API_KEY=

# Slack — for incident alerts (posts to a channel automatically)
# Get at: api.slack.com → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Resend — for email delivery monitoring
# Get at: resend.com → API Keys
RESEND_API_KEY=

# PageSpeed — for Lighthouse scores in performance-engineer
# Get at: console.cloud.google.com → APIs → PageSpeed Insights
PAGESPEED_API_KEY=

# ─── PER-PROJECT (add one set per project) ─────────────────────────────────

# Project 1
PROJECT1_SUPABASE_URL=
PROJECT1_SUPABASE_ANON_KEY=

# Project 2
PROJECT2_SUPABASE_URL=
PROJECT2_SUPABASE_ANON_KEY=

# Project 3
PROJECT3_SUPABASE_URL=
PROJECT3_SUPABASE_ANON_KEY=
